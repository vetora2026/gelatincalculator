---
import "../../styles/global.css";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "How Much Gelatin Per Cup of Liquid?",
  description:
    "Standard ratio: 2.25 tsp gelatin powder per cup of liquid for a medium set. Here's the full reference by texture, plus what affects gelling strength.",
  url: "https://gelatincalculator.com/how-much-gelatin-per-cup-of-liquid/",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How much gelatin powder do I use per cup of liquid?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "For a standard medium set (firm enough to unmold, like classic gelatin desserts), use approximately 2.25 teaspoons (7g) of gelatin powder per cup (240ml) of liquid. For a softer panna cotta-style set, use approximately 1.5 teaspoons (4.7g). These ratios assume powder at approximately 200–225 bloom.",
      },
    },
    {
      "@type": "Question",
      name: "Does acid affect how gelatin sets?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Acid weakens the gelatin network. A dessert with a high proportion of acidic liquid — citrus juice, wine, vinegar — may require up to 50% more gelatin than a water-based preparation to achieve the same set. Highly acidic ingredients should be added after the gelatin has partially set, if possible.",
      },
    },
    {
      "@type": "Question",
      name: "Why won't my gelatin set with fresh pineapple?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Fresh pineapple, kiwi, papaya, mango, and figs contain proteolytic enzymes (bromelain in pineapple, actinidin in kiwi) that break down the protein chains gelatin relies on for gelling. The gelatin is destroyed before it can set. Canned or cooked versions of these fruits are safe — the heat from processing deactivates the enzymes.",
      },
    },
    {
      "@type": "Question",
      name: "At what temperature does gelatin set?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Gelatin begins to set at approximately 59°F (15°C) and melts at approximately 95°F (35°C) — just below body temperature. This melt-in-mouth property is why gelatin-set desserts feel different from agar-set ones, which remain firm at room temperature.",
      },
    },
  ],
};
---

<html lang="en">
  <head>
    <BaseHead
      title="How Much Gelatin Per Cup of Liquid? (Reference Table) | gelatincalculator.com"
      description="Standard ratio: 2.25 tsp gelatin powder per cup of liquid for a medium set. Here's the full reference by texture, plus what affects gelling strength."
      path="/how-much-gelatin-per-cup-of-liquid/"
    />
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(articleSchema)}</script>`} />
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(faqSchema)}</script>`} />
  </head>
  <body class="bg-white text-stone-900">
    <nav class="border-b border-stone-200">
      <div class="max-w-5xl mx-auto px-5 py-4 flex items-center justify-between">
        <a href="/" class="font-serif text-xl text-stone-900">gelatincalculator.com</a>
        <div class="flex gap-5 text-sm text-stone-600">
          <a href="/about" class="hover:text-amber-700">About</a>
          <a href="/privacy" class="hover:text-amber-700">Privacy</a>
        </div>
      </div>
    </nav>

    <main class="max-w-2xl mx-auto px-5 py-16">
      <h1 class="font-serif text-5xl text-stone-900 mb-3">How Much Gelatin Per Cup of Liquid?</h1>
      <p class="text-stone-500 text-sm mb-12">Reference ratios by texture, with variables that affect the set</p>

      <div class="text-stone-700 leading-relaxed space-y-12">

        <section>
          <h2 class="font-serif text-2xl text-stone-900 mb-4">Ratios by desired texture</h2>
          <p class="text-stone-500 text-sm mb-4">
            Based on gelatin powder at approximately 200–225 bloom (Knox or equivalent US grocery powder)
            in a water-based preparation at standard kitchen temperature. One cup = 240ml.
          </p>
          <div class="overflow-x-auto -mx-1">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="border-b border-stone-200 text-left text-stone-500">
                  <th class="py-2 px-2 font-medium">Desired Texture</th>
                  <th class="py-2 px-2 font-medium">Powder per Cup (~200–225 bloom)</th>
                  <th class="py-2 px-2 font-medium">Silver Sheets (160 bloom) per Cup</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-stone-100 text-stone-700">
                <tr>
                  <td class="py-3 px-2">
                    <p class="font-medium text-stone-900">Soft set</p>
                    <p class="text-stone-500 text-xs mt-0.5">Barely holds shape — panna cotta</p>
                  </td>
                  <td class="py-3 px-2">~1.5 tsp (~4.7g)</td>
                  <td class="py-3 px-2">~2.5 sheets</td>
                </tr>
                <tr>
                  <td class="py-3 px-2">
                    <p class="font-medium text-stone-900">Medium set</p>
                    <p class="text-stone-500 text-xs mt-0.5">Standard jello, mousse, sliceable</p>
                  </td>
                  <td class="py-3 px-2">~2.25 tsp (~7g)</td>
                  <td class="py-3 px-2">~4 sheets</td>
                </tr>
                <tr>
                  <td class="py-3 px-2">
                    <p class="font-medium text-stone-900">Firm set</p>
                    <p class="text-stone-500 text-xs mt-0.5">Clean-cutting, unmoldable</p>
                  </td>
                  <td class="py-3 px-2">~3 tsp (~9.4g)</td>
                  <td class="py-3 px-2">~5.5 sheets</td>
                </tr>
                <tr>
                  <td class="py-3 px-2">
                    <p class="font-medium text-stone-900">Very firm</p>
                    <p class="text-stone-500 text-xs mt-0.5">Aspic, gummy, structural</p>
                  </td>
                  <td class="py-3 px-2">~4+ tsp (~12.5g)</td>
                  <td class="py-3 px-2">~7+ sheets</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-stone-500 mt-3 leading-relaxed">
            Sheet counts assume standard weight per sheet (~2.5g silver, ~2g gold). Actual sheet
            weights vary by supplier. For critical applications, weigh rather than count.
          </p>
          <div class="mt-5 p-4 bg-amber-50 border border-amber-200 rounded-xl">
            <p class="text-sm text-amber-900">
              If your gelatin's bloom strength differs from the values above,{" "}
              <a href="/" class="underline underline-offset-4 font-medium hover:text-amber-700">
                calculate exact amounts for your recipe →
              </a>
            </p>
          </div>
        </section>

        <section>
          <h2 class="font-serif text-2xl text-stone-900 mb-4">Variables that affect the set</h2>

          <div class="space-y-4">
            <div class="border border-stone-200 rounded-xl p-4">
              <p class="font-medium text-stone-900 mb-2">Acid content</p>
              <p class="text-stone-600 text-sm leading-relaxed">
                Acid weakens the gelatin protein network. A preparation with 25% lemon
                juice by volume may require up to 50% more gelatin to achieve the same
                set as a water-based recipe. Red wine, white wine, and other acidic
                liquids have a similar but generally smaller effect depending on pH.
              </p>
            </div>

            <div class="border border-stone-200 rounded-xl p-4">
              <p class="font-medium text-stone-900 mb-2">Sugar</p>
              <p class="text-stone-600 text-sm leading-relaxed">
                Sugar has a mild reinforcing effect on gelatin networks at typical
                dessert concentrations (15–30% by weight). Highly sweetened preparations
                — candy, gummies, marshmallows — may set slightly firmer than the base
                ratios above for the same gelatin quantity.
              </p>
            </div>

            <div class="border border-stone-200 rounded-xl p-4">
              <p class="font-medium text-stone-900 mb-2">Dairy</p>
              <p class="text-stone-600 text-sm leading-relaxed">
                Cream and milk set slightly softer than water at the same gelatin
                concentration. Fat content interrupts the gelatin network. Panna cotta —
                which is primarily cream — typically uses the soft-set ratio (1.5 tsp
                per cup) rather than the medium-set ratio used for water-based
                preparations.
              </p>
            </div>

            <div class="border border-stone-200 rounded-xl p-4">
              <p class="font-medium text-stone-900 mb-2">Proteolytic enzymes</p>
              <p class="text-stone-600 text-sm leading-relaxed">
                Fresh pineapple, kiwi, papaya, mango, and figs contain enzymes
                (bromelain, actinidin, papain) that break down gelatin's protein chains.
                Adding any of these fresh will prevent the gelatin from setting
                entirely. Canned or cooked versions of these fruits are safe — the
                heating process during canning deactivates the enzymes.
              </p>
            </div>
          </div>
        </section>

        <section>
          <h2 class="font-serif text-2xl text-stone-900 mb-3">The temperature factor</h2>
          <div class="grid grid-cols-2 gap-4 mb-5">
            <div class="border border-stone-200 rounded-xl p-5">
              <p class="text-xs text-stone-500 uppercase tracking-wide mb-2">Sets at</p>
              <p class="font-serif text-3xl text-stone-900 mb-1">59°F</p>
              <p class="text-sm text-stone-600">15°C — requires refrigeration in most kitchens</p>
            </div>
            <div class="border border-stone-200 rounded-xl p-5">
              <p class="text-xs text-stone-500 uppercase tracking-wide mb-2">Melts at</p>
              <p class="font-serif text-3xl text-stone-900 mb-1">95°F</p>
              <p class="text-sm text-stone-600">35°C — just below body temperature</p>
            </div>
          </div>
          <p>
            Gelatin's narrow set-to-melt range is what gives it the "melt on the tongue"
            quality in desserts like panna cotta and bavarois. Agar agar, by contrast,
            sets at approximately 104°F (40°C) and melts at approximately 185°F (85°C),
            which is why agar-set preparations hold their shape at room temperature and
            feel firm rather than yielding when eaten.
          </p>
          <p class="mt-3">
            Chilling time affects the final set. A gelatin dessert that is still soft
            after two hours in the refrigerator may simply need another hour. Most
            preparations reach their final set within four to six hours. Overnight
            chilling gives the most consistent results for critical applications.
          </p>
        </section>

        <section>
          <h2 class="font-serif text-2xl text-stone-900 mb-7">Frequently asked questions</h2>
          <div class="space-y-7">
            <div>
              <h3 class="font-serif text-lg text-stone-900 mb-2">How much gelatin powder do I use per cup of liquid?</h3>
              <p class="text-stone-600 leading-relaxed">
                For a standard medium set, approximately 2.25 teaspoons (7g) of gelatin
                powder per cup (240ml) of liquid. For a softer panna cotta-style set,
                approximately 1.5 teaspoons (4.7g). These ratios assume powder at
                approximately 200–225 bloom in a water-based preparation. For dairy or
                acidic liquids, adjust upward.
              </p>
            </div>
            <div>
              <h3 class="font-serif text-lg text-stone-900 mb-2">Does acid affect how gelatin sets?</h3>
              <p class="text-stone-600 leading-relaxed">
                Yes. Acid weakens the gelatin network. A dessert with a high proportion
                of acidic liquid — citrus juice, wine, vinegar — may require up to 50%
                more gelatin than a water-based preparation to achieve the same set.
                The exact adjustment depends on the pH and proportion of acidic liquid
                in the recipe.
              </p>
            </div>
            <div>
              <h3 class="font-serif text-lg text-stone-900 mb-2">Why won't my gelatin set with fresh pineapple?</h3>
              <p class="text-stone-600 leading-relaxed">
                Fresh pineapple contains bromelain, an enzyme that breaks down the
                protein chains gelatin relies on. The same effect occurs with fresh kiwi
                (actinidin), fresh papaya (papain), fresh mango, and fresh figs.
                Canned or cooked versions of these fruits are safe because the heat
                from processing deactivates the enzymes.
              </p>
            </div>
            <div>
              <h3 class="font-serif text-lg text-stone-900 mb-2">At what temperature does gelatin set?</h3>
              <p class="text-stone-600 leading-relaxed">
                Gelatin begins to set at approximately 59°F (15°C) and melts at
                approximately 95°F (35°C) — just below body temperature. Standard
                refrigerators run at 35–38°F, which is well within the setting range.
                Most preparations reach a stable set within 4–6 hours; overnight chilling
                is recommended for preparations that need to be unmolded cleanly.
              </p>
            </div>
          </div>
        </section>

        <section>
          <h2 class="font-serif text-2xl text-stone-900 mb-4">Related articles</h2>
          <div class="space-y-3">
            <a href="/gelatin-sheets-vs-powder/" class="block border border-stone-200 rounded-xl p-4 hover:border-amber-300 transition-colors">
              <p class="font-medium text-stone-900 mb-1">Gelatin Sheets vs Powder: What's the Difference?</p>
              <p class="text-stone-500 text-sm">Format comparison: measuring method, clarity, bloom grades, and when each works best.</p>
            </a>
            <a href="/what-is-gelatin-bloom-strength/" class="block border border-stone-200 rounded-xl p-4 hover:border-amber-300 transition-colors">
              <p class="font-medium text-stone-900 mb-1">What Is Gelatin Bloom Strength?</p>
              <p class="text-stone-500 text-sm">How the bloom test works and why the numbers matter for recipe conversions.</p>
            </a>
            <a href="/" class="block border border-stone-200 rounded-xl p-4 hover:border-amber-300 transition-colors">
              <p class="font-medium text-stone-900 mb-1">Bloom Strength Calculator</p>
              <p class="text-stone-500 text-sm">Diagnose your gelatin's bloom value and convert recipe quantities to match what you have.</p>
            </a>
          </div>
        </section>

      </div>
    </main>

    <Footer />
  </body>
</html>
